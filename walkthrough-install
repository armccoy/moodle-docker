#!/usr/bin/env bash

# Run basic install
function basic_install() {
    echo -e "${C_GREEN}Installing Moodle...${C_RESET}"
    export MOODLE_DOCKER_WWWROOT=$moodle_path
    export MOODLE_DOCKER_DB=$database
    cp config.docker-template.php $moodle_path/config.php
    bin/moodle-docker-compose up -d
    echo ""
    echo -e "You can now access your new Moodle instance at ${C_UWHITE}http://localhost:8000${C_RESET}"
    echo ""
    exit 0
}

# Run advanced install
function advanced_install() {
    moodle_path=$1
    database=$2
    db_port=$3
    web_host=$4
    web_port=$5
    project_name=$6
    selected_plugins=$7

    echo -e "${C_GREEN}Installing Moodle...${C_RESET}"
    export MOODLE_DOCKER_WWWROOT=$moodle_path
    export MOODLE_DOCKER_DB=$database
    export MOODLE_DOCKER_DB_PORT=$db_port
    export MOODLE_DOCKER_WEB_HOST=$web_host
    export MOODLE_DOCKER_WEB_PORT=$web_port
    export COMPOSE_PROJECT_NAME=$project_name
    cp config.docker-template.php $moodle_path/config.php
    bin/moodle-docker-compose up -d
    echo ""

    # Install selected developer plugins
    for plugin in $selected_plugins; do
        case $plugin in
            codechk)
                git clone https://github.com/moodlehq/moodle-local_codechecker.git $moodle_path/local/codechecker
                ;;
            phpdocchk)
                git clone https://github.com/moodlehq/moodle-local_moodlecheck.git $moodle_path/local/moodlecheck
                ;;
            pluginskel)
                git clone https://github.com/mudrd8mz/moodle-tool_pluginskel.git $moodle_path/admin/tool/pluginskel
                ;;
        esac
    done

    echo -e "You can now access your new Moodle instance at ${C_UWHITE}http://$web_host:$web_port${C_RESET}"
    echo ""
    exit 0
}

# Function to convert plugin keys to names
function get_plugin_names() {
    local keys="$1"
    local names=()
    local options=(
        "codechk|Code Checker|Checks PHP files for Moodle coding style compliance"
        "phpdocchk|Moodle PHPdoc Check|Checks for proper phpdoc content and formatting"
        "pluginskel|Moodle Plugin Skeleton Generator|Quickly generates code skeleton for a new Moodle plugin"
    )

    for key in $keys; do
        for option in "${options[@]}"; do
            IFS="|" read -r option_key option_name option_desc <<< "$option"
            if [[ "$option_key" == "$key" ]]; then
                names+=(" $option_name")
                break
            fi
        done
    done

    # Join names with comma and space
    local IFS=", "
    echo "${names[*]}"
}

# Set up colors
C_RED="\033[0;31m"
C_ORANGE="\033[38;5;208m"
C_YELLOW="\033[33m"
C_BLUE="\033[38;5;080m"
C_GREEN="\033[0;32m"
C_UWHITE="\033[4;37m"
C_RESET="\033[0m"
C_PF_YELLOW='\e[0;33m'
C_PF_RESET='\e[0m'

# Step 1: Welcome message
echo -e "${C_ORANGE}=========================================="
echo -e "      Welcome to Moodle Docker Setup"
echo -e "==========================================${C_RESET}"
echo "This is a basic Moodle install with some advanced options."
echo -e "For full customization options, please see the README at ${C_UWHITE}https://github.com/moodlehq/moodle-docker.${C_RESET}"
echo ""
echo "Before we begin, make sure you have:"
echo ""
echo -e "    ${C_YELLOW}1. Docker installed"
echo -e "    2. Docker Compose installed"
echo -e "    3. Git installed"
echo -e "    4. Cloned the Moodle codebase"
echo -e "    5. Checked out the Moodle branch you want to install${C_RESET}"
echo ""
# Confirmation prompt
read -p "Okay to proceed? (Y/n): " confirm
if [ -z "$confirm" ] || [[ "$confirm" =~ ^[Yy]$ ]]; then
    echo ""
elif [[ "$confirm" =~ ^[Nn]$ ]]; then
    echo ""
    echo "Installation cancelled."
    exit 0
else
    echo "Please enter Y or n."
fi

# Step 2: Get Moodle codebase filepath
echo -e "${C_BLUE}Step 1: Moodle Codebase Location"
echo -e "---------------------------------${C_RESET}"
read -p "What is the filepath of your Moodle codebase? " moodle_path
echo ""

# Step 3: Database selection
echo -e "${C_BLUE}Step 2: Database Selection"
echo -e "--------------------------${C_RESET}"
echo "Which database would you like to use?"
echo ""
echo -e "    ${C_YELLOW}1. pgsql"
echo -e "    2. mariadb"
echo -e "    3. mysql"
echo -e "    4. mssql"
echo -e "    5. oracle${C_RESET}"
echo ""

while true; do
    read -p "Enter your choice (1-5): " db_choice
    case $db_choice in
        1) database="pgsql"; break;;
        2) database="mariadb"; break;;
        3) database="mysql"; break;;
        4) database="mssql"; break;;
        5) database="oracle"; break;;
        *) echo "Invalid choice. Please enter a number between 1 and 5.";;
    esac
done
echo "Selected database: $database"
echo ""

# Step 4: Basic or Advanced setup
echo -e "${C_BLUE}Step 3: Installation Type"
echo -e "-------------------------${C_RESET}"
echo "Would you like to:"
echo ""
echo -e "    ${C_YELLOW}1. Proceed with basic installation"
echo -e "    2. Set up advanced settings${C_RESET}"
echo ""

while true; do
    read -p "Enter your choice (1-2): " setup_choice
    case $setup_choice in
        1) advanced_setup=false; break;;
        2) advanced_setup=true; break;;
        *) echo "Invalid choice. Please enter 1 or 2.";;
    esac
done
echo ""

# If basic install chosen, skip to installation
if [ "$advanced_setup" = false ]; then
    echo -e "${C_ORANGE}=========================================="
    echo -e "          Configuration Summary:"
    echo -e "==========================================${C_RESET}"
    echo -e "    ${C_YELLOW}Moodle Path:${C_RESET} $moodle_path"
    echo -e "    ${C_YELLOW}Database:${C_RESET} $database"
    echo ""
    while true; do
        read -p "Proceed with basic installation? (Y/n): " confirm
        if [ -z "$confirm" ] || [[ "$confirm" =~ ^[Yy]$ ]]; then
            echo ""
            basic_install $moodle_path $database
        elif [[ "$confirm" =~ ^[Nn]$ ]]; then
            echo ""
            echo "Installation cancelled."
            exit 0
        else
            echo "Please enter Y or n."
        fi
    done
fi

# Step 5: Database port (Advanced settings)
echo -e "${C_ORANGE}=========================================="
echo -e "            Advanced Settings"
echo -e "==========================================${C_RESET}"
echo ""
echo -e "${C_BLUE}Step 4: Database Port"
echo -e "---------------------${C_RESET}"
echo -e "${C_GREEN}TIP:${C_RESET} Entering a non-standard database port allows multiple Moodle instances"
echo "to each have their own database."
echo ""

while true; do
    read -p "Enter the database port (default: 3360): " db_port
    if [ -z "$db_port" ]; then
        db_port="3360"
        break
    elif [[ "$db_port" =~ ^[0-9]+$ ]]; then
        break
    else
        echo -e "${C_RED}Invalid input. Please enter numbers only.${C_RESET}"
        echo ""
    fi
done
echo "Database port set to: $db_port"
echo ""

# Step 7: Web host
echo -e "${C_BLUE}Step 5: Web Host"
echo -e "----------------${C_RESET}"
read -p "Enter the web host (default: localhost): " web_host
if [ -z "$web_host" ]; then
    web_host="localhost"
fi
echo "Web host set to: $web_host"
echo ""

# Step 8: Web port
echo -e "${C_BLUE}Step 6: Web Port"
echo -e "----------------${C_RESET}"
echo -e "${C_GREEN}TIP:${C_RESET} Entering a non-standard web port allows you to run multiple Moodle"
echo "instances simultaneously. If set to '0', no web port will be used."
echo ""

while true; do
    read -p "Enter the web port (default: 8000): " web_port
    if [ -z "$web_port" ]; then
        web_port="8000"
        break
    elif [[ "$web_port" =~ ^[0-9]+$ ]]; then
        break
    else
        echo -e "${C_RED}Invalid input. Please enter numbers only.${C_RESET}"
        echo ""
    fi
done
echo "Web port set to: $web_port"
echo ""

# Step 9: Project name
echo -e "${C_BLUE}Step 7: Project Name"
echo -e "--------------------${C_RESET}"
echo "Choose the project name. This is the name that will appear for the project"
echo "in the Docker dashboard. Project names must contain only lowercase letters,"
echo "decimal digits, dashes, and underscores, and must begin with a lowercase"
echo "letter or decimal digit."
echo ""
echo -e "${C_GREEN}TIP:${C_RESET} Entering a unique project name allows you to run multiple Moodle"
echo "instances simultaneously."
echo ""

while true; do
    read -p "Enter the project name: (default: moodle-docker): " project_name
    if [ -z "$project_name" ]; then
        project_name="moodle-docker"
        break
    elif [[ "$project_name" =~ ^[a-z0-9][a-z0-9_-]*$ ]]; then
        break
    else
        echo -e "${C_RED}Invalid project name. Must contain only lowercase letters, digits,"
        echo -e "dashes, and underscores, and must begin with a lowercase letter or digit.${C_RESET}"
        echo ""
    fi
done
echo "Project name set to: $project_name"
echo ""

# Step 10: Developer plugins (manual selector)
echo -e "${C_BLUE}Step 8: Developer Plugins"
echo -e "--------------------${C_RESET}"
echo "Would you like to pre-install some recommended developer plugins?"
echo ""

while true; do
    read -p "Choose developer plugins? (Y/n): " confirm
    if [ -z "$confirm" ] || [[ "$confirm" =~ ^[Yy]$ ]]; then
        # Interactive plugin selection (arrow keys + spacebar)
        choose_plugins() {
            local options=(
                "codechk|Code Checker|Checks PHP files for Moodle coding style compliance"
                "phpdocchk|Moodle PHPdoc Check|Checks for proper phpdoc content and formatting"
                "pluginskel|Moodle Plugin Skeleton Generator|Quickly generates code skeleton for a new Moodle plugin"
            )
            local selected=()
            local cursor=0
            local key
            while true; do
                clear
                echo -e "${C_GREEN}Use ↑/↓ to move, SPACE to toggle selection, ENTER to confirm.${C_RESET}"
                echo
                for i in "${!options[@]}"; do
                    IFS="|" read -r key name desc <<< "${options[$i]}"
                    if [[ $i -eq $cursor ]]; then printf "> "; else printf "  "; fi
                    if [[ " ${selected[*]} " == *" $key "* ]]; then
                        printf "${C_PF_YELLOW}[${C_PF_RESET}x${C_PF_YELLOW}] %s${C_PF_RESET} - %s\n" "$name" "$desc"
                    else
                        printf "${C_PF_YELLOW}[ ] %s${C_PF_RESET} - %s\n" "$name" "$desc"
                    fi
                done
                IFS= read -rsn1 key
                if [[ $key == $'\x1b' ]]; then
                    read -rsn2 key
                    case $key in
                        "[A") ((cursor--));;
                        "[B") ((cursor++));;
                    esac
                    ((cursor < 0)) && cursor=$((${#options[@]} - 1))
                    ((cursor >= ${#options[@]})) && cursor=0
                elif [[ $key == " " ]]; then
                    IFS="|" read -r keycode _ <<< "${options[$cursor]}"
                    if [[ " ${selected[*]} " == *" $keycode "* ]]; then
                        selected=(${selected[@]//$keycode})
                    else
                        selected+=("$keycode")
                    fi
                elif [[ $key == "" ]]; then
                    break
                fi
            done
            SELECTED_PLUGINS="${selected[*]}"
        }
        choose_plugins
        break
    elif [[ "$confirm" =~ ^[Nn]$ ]]; then
        SELECTED_PLUGINS=""
        break
    else
        echo -e "${C_RED}Please enter Y or n.${C_RESET}"
    fi
done
echo ""

# Step 11: Installation confirmation
echo -e "${C_ORANGE}=========================================="
echo -e "          Configuration Summary:"
echo -e "==========================================${C_RESET}"
echo -e "    ${C_YELLOW}Moodle Path:${C_RESET} $moodle_path"
echo -e "    ${C_YELLOW}Database:${C_RESET} $database"
echo -e "    ${C_YELLOW}Database Port:${C_RESET} $db_port"
echo -e "    ${C_YELLOW}Web Host:${C_RESET} $web_host"
echo -e "    ${C_YELLOW}Web Port:${C_RESET} $web_port"
echo -e "    ${C_YELLOW}Project Name:${C_RESET} $project_name"

# Convert plugin keys to names for display
if [ -n "$SELECTED_PLUGINS" ]; then
    PLUGIN_NAMES=$(get_plugin_names "$SELECTED_PLUGINS")
    echo -e "    ${C_YELLOW}Selected Plugins:${C_RESET}$PLUGIN_NAMES"
else
    echo -e "    ${C_YELLOW}Selected Plugins:${C_RESET} None"
fi
echo ""

while true; do
    read -p "Proceed with advanced installation? (Y/n): " confirm
    if [ -z "$confirm" ] || [[ "$confirm" =~ ^[Yy]$ ]]; then
        echo ""
        advanced_install $moodle_path $database $db_port $web_host $web_port $project_name "$SELECTED_PLUGINS"
    elif [[ "$confirm" =~ ^[Nn]$ ]]; then
        echo ""
        echo "Installation cancelled."
        exit 0
    else
        echo -e "${C_RED}Please enter Y or n.${C_RESET}"
    fi
done